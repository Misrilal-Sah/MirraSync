# ─── App ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── JWT ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_EXPIRES_IN=7d

# ─── Encryption (for API keys stored in DB) ─────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ─── MySQL Database ─────────────────────────────────────────────
DATABASE_URL=mysql://root:your_db_password@localhost:3306/mirrasync

# ─── Google OAuth ───────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── SMTP (Gmail App Password) ──────────────────────────────────
# Generate App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=MirraSync
SMTP_FROM_EMAIL=your_gmail_address@gmail.com

# ─── Cloudinary (File Uploads) ──────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── AI Provider Keys (Server-Side) ─────────────────────────────

# GitHub Models — https://github.com/marketplace/models
# Key format: github_pat_...
GITHUB_MODELS_API_KEY=github_pat_your_token_here
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# Google AI Studio — https://aistudio.google.com/app/apikey
# Key format: AIzaSy...
GOOGLE_AI_API_KEY=AIzaSy_your_google_ai_api_key_here
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Groq — https://console.groq.com/keys
# Key format: gsk_...
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Cerebras — https://cloud.cerebras.ai/
# Key format: csk-...
CEREBRAS_API_KEY=csk-your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Cohere — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here
COHERE_BASE_URL=https://api.cohere.com/v2

# Mistral La Plateforme — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# OpenRouter — https://openrouter.ai/keys
# Key format: sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cloudflare Workers AI — https://dash.cloudflare.com/profile/api-tokens
# Need BOTH the API key and your Account ID
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4/accounts

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Brevo — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your_brevo_api_key_here
